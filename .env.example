# Name of the running devcontainer as shown by `docker ps`
DEVCONTAINER_NAME=your-devcontainer-name

# Working directory inside the devcontainer (must have workspace trust accepted)
WORKING_DIR=/workspaces/your-project

# Port the launcher web UI will be served on
PORT=8765

# Seconds to wait for claude remote-control to output the URL before timing out
URL_CAPTURE_TIMEOUT=30

# Global claude flags (before the subcommand)
CLAUDE_GLOBAL_FLAGS=--plugin-dir packages/local-mcp-servers/your-plugin

# Flags passed to remote-control subcommand
CLAUDE_RC_FLAGS=--permission-mode bypassPermissions

# Tailscale auth key (generate at https://login.tailscale.com/admin/settings/keys)
TAILSCALE_AUTHKEY=

# Tailscale node hostname (shows up in your admin panel)
TAILSCALE_HOSTNAME=claude-launcher

# Date your Tailscale auth key expires (ISO format). Used for expiry warnings.
TS_KEY_EXPIRES=2026-06-05

# Workspot definitions (JSON array). container=null means run locally inside the launcher.
WORKSPOTS=[{"name":"exxdev","container":"your-devcontainer-name","dir":"/workspaces/your-project"},{"name":"claude-bot","container":null,"dir":"/workspace/claude-bot"}]
